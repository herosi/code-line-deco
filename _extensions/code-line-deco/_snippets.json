{
  "Inline code decoration": {
    "prefix": "code-deco-inline",
    "body": [
      "```{.${1:python} code-line-deco-ranges=\"${2:1:5-10,2:7-}\" code-line-deco-effects=\"${3:shade|underline|font-color,background-color|frame|bold}\"}",
      "${4:def main():}",
      "${5:    print(\"hello world\")}",
      "```"
    ],
    "description": "Insert a code block with inline decoration ranges and effects."
  },
  "Filename decoration": {
    "prefix": "code-deco-filename",
    "body": [
      "```{.${1:python} filename=\"${2:example.py}\" code-line-deco-ranges=\"${3:0:1-3,2:6-13}\" code-line-deco-effects=\"${4:shade|underline:red|font-color:#0000ff|bold,background-color:orange|frame:green}\"}",
      "${5:def main():}",
      "${6:    print(\"hello\")}",
      "```"
    ],
    "description": "Insert a code block with filename and line decorations."
  }
}
